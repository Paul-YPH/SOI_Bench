// Demo: Nextflow config for a SLURM + Singularity HPC cluster.
// Replace all <placeholder> values with your own paths and cluster settings.

params.base_dir = "/path/to/your/project"
params.run_mode = "experiment"

workDir = "/path/to/work_${params.run_mode}"

singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = "${params.base_dir}/envs/singularity_cache"
    runOptions = "--nv -B /path/to/shared/storage,${params.base_dir}:${params.base_dir}"
}

params {
    shared_py_dir   = "${params.base_dir}/shared_py"
    tools_py_dir    = "${params.base_dir}/tools_py"
    metrics_py_dir  = "${params.base_dir}/"
    container_cache = "${params.base_dir}/cache/container_outputs"
    data_dir        = "${params.base_dir}/data_${params.run_mode}"
    out_dir         = "/path/to/output_${params.run_mode}"

    datasets  = ['D1']
    tools     = ['BANKSY']
    large_ids = ['D5', 'D6']   // datasets needing extra memory/time

    failed_blacklist = []       // add '<dataset>_<tool>' strings to skip known failures

    param_space = [
        seed: [42],             // multiple values → replicate runs
        gene: ['all'],          // 'all' | 'hvg<N>' | 'svg<N>'
        // knn: [5, 10, 15],   // uncomment for grid search
        // pcs: [10, 20, 50],
    ]

    // Which hyperparameters each tool accepts (knn / pcs / gene).
    // Tools not listed here receive no extra arguments.
    tool_config = [
        'BANKSY':   ['knn', 'gene'],
        'CAST':     ['gene'],
        'DeepST':   ['knn', 'pcs', 'gene'],
        'GraphST':  ['gene'],
        'STAGATE':  ['knn', 'gene'],
        // … one entry per tool following the same pattern
        'SMOPCA':         [],
        'SpatialGlue':    [],
    ]

    global_args = [clust: 'mclust']

    // selection_map = ['D1': ['BANKSY', 'CAST']]  // per-dataset tool allow-list
}

process {
    executor = 'slurm'
    queue    = '<your-default-queue>'
    cpus     = 4
    memory   = '8 GB'
    time     = '0.5h'
    maxForks = 20
    cleanup  = true
    shell    = ['bash', '-C', '-e', '-u', '-o', 'pipefail']

    env {
        PYTHONPATH      = "${params.shared_py_dir}:${params.tools_py_dir}"
        NUMBA_CACHE_DIR = "${params.container_cache}/numba"
        MPLCONFIGDIR    = "${params.container_cache}/matplotlib"
        XDG_CONFIG_HOME = "${params.container_cache}/xdg_config"
        XDG_CACHE_HOME  = "${params.container_cache}/xdg_cache"
        XDG_DATA_HOME   = "${params.container_cache}/xdg_data"
        DGL_HOME        = "${params.container_cache}/dgl"
        DGLBACKEND      = "pytorch"
        PATH            = "/opt/conda-env/bin:\$PATH"
        R_HOME          = "/opt/conda-env/lib/R"
        R_LIBS_USER     = "/opt/conda-env/lib/R/library"
        R_LIBS_SITE     = ""
    }

    beforeScript = """
        mkdir -p ${params.container_cache}/{numba,matplotlib,xdg_config,xdg_cache,xdg_data,dgl,home}
        export HOME=${params.container_cache}/home
    """

    // Pass R/conda env vars into the Singularity container
    containerOptions = {
        "--env R_HOME=/opt/conda-env/lib/R " +
        "--env LD_LIBRARY_PATH=/opt/conda-env/lib/R/lib:/opt/conda-env/lib:\$LD_LIBRARY_PATH " +
        "--env R_LIBS_USER=/opt/conda-env/lib/R/library " +
        "--env PATH=/opt/conda-env/bin:\$PATH "
    }

    errorStrategy = { log.error "FAILED: ${task.name} [${task.tag}] exit=${task.exitStatus}"; return 'ignore' }

    withLabel: 'python_gpu_process' {
        queue          = '<your-gpu-queue>'
        cpus           = 8
        memory         = { (task.tag?.split('_')[0] in params.large_ids) ? '128 GB' : '32 GB' }
        time           = { (task.tag?.split('_')[0] in params.large_ids) ? '12h'    : '1h'    }
        clusterOptions = '--gres=gpu:<gpu-type>:1 --account=<your-account>'
        maxForks       = 32
    }

    // python_cpu_process and r_process share the same resource profile
    withLabel: 'python_cpu_process' {
        queue    = '<your-cpu-queue>'
        cpus     = 8
        memory   = { (task.tag?.split('_')[0] in params.large_ids) ? '512 GB' : '64 GB' }
        time     = { (task.tag?.split('_')[0] in params.large_ids) ? '12h'    : '2h'    }
        maxForks = 32
    }

    withLabel: 'r_process' {
        queue    = '<your-cpu-queue>'
        cpus     = 8
        memory   = { (task.tag?.split('_')[0] in params.large_ids) ? '512 GB' : '64 GB' }
        time     = { (task.tag?.split('_')[0] in params.large_ids) ? '12h'    : '2h'    }
        maxForks = 32
    }
}

executor {
    $slurm {
        queueSize       = 40
        submitRateLimit = '5/1min'
    }
}

trace {
    enabled   = true
    overwrite = false
    file      = "${params.out_dir}/trace-${params.run_mode}.txt"
    fields    = 'task_id, name, tag, hash, native_id, status, queue, exit, realtime, cpus, %cpu, memory, peak_rss, peak_vmem'
}
